{
  "name": "lgtm-cat-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 2222",
    "build": "next build",
    "start": "next start -p 2222",
    "lint:prettier": "prettier --check --log-level=warn '**/!(*.min|*-lock).{yaml,yml,md,mdx}'",
    "prettier": "prettier --write --log-level=warn '**/!(*.min|*-lock).{yaml,yml,md,mdx}'",
    "lint": "ultracite check && npm run lint:prettier",
    "format": "ultracite fix && npm run prettier",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "sync:agents-docs": "tsx src/scripts/copy-agents-markdown.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1019.0",
    "@aws-sdk/s3-request-presigner": "3.1019.0",
    "@heroui/react": "2.8.10",
    "@next/third-parties": "16.2.1",
    "@sentry/nextjs": "10.46.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "@vercel/edge-config": "1.4.3",
    "@vercel/functions": "3.4.3",
    "framer-motion": "12.38.0",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "prism-react-renderer": "2.4.1",
    "prismjs": "1.30.0",
    "react": "19.2.4",
    "react-aria-components": "1.16.0",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "recharts": "3.8.1",
    "usehooks-ts": "3.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@chromatic-com/storybook": "5.1.1",
    "@iconify/react": "6.0.2",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-onboarding": "10.3.3",
    "@storybook/addon-viewport": "9.0.8",
    "@storybook/addon-vitest": "10.3.3",
    "@storybook/nextjs-vite": "10.3.3",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "ajv": "8.18.0",
    "babel-plugin-react-compiler": "1.0.0",
    "chromatic": "16.0.0",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "msw": "2.12.14",
    "msw-storybook-addon": "2.0.6",
    "npm-run-all": "4.1.5",
    "playwright": "1.58.2",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "storybook": "10.3.3",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "ultracite": "7.4.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
